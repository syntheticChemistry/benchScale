# benchScale .gitignore

# Lab state (runtime data)
.state/
*.state

# VM/Container state
*.qcow2
*.img
*.vmdk

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts (if we add Rust tooling later)
target/
Cargo.lock

# Test results
test-results/
*.junit.xml

# Custom manifests (user-created)
manifests/*.local.yaml
configs/*.local.yaml

# SSH keys (if used for VM access)
*.pem
*.key
!*.pub

# Backup files
*.bak
*.backup

# Node modules (if we add any tooling)
node_modules/

